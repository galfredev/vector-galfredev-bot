{
  "meta": {
    "lastTouchedVersion": "2026.3.24"
  },
  "env": {
    "GEMINI_API_KEY": "replace-with-gemini-api-key",
    "OPENAI_API_KEY": "replace-with-openai-api-key"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash",
        "fallbacks": [
          "openai/gpt-5.4-mini"
        ]
      },
      "models": {
        "google/gemini-2.5-flash": {},
        "openai/gpt-5.4-mini": {}
      },
      "workspace": "/opt/galfre-bot/.openclaw/workspace"
    },
    "list": [
      {
        "id": "main",
        "name": "main",
        "workspace": "/opt/galfre-bot/.openclaw/workspace",
        "agentDir": "/opt/galfre-bot/.openclaw/agents/main/agent",
        "tools": {
          "deny": [
            "group:web",
            "browser",
            "exec",
            "process",
            "write",
            "edit",
            "apply_patch"
          ]
        }
      }
    ]
  },
  "tools": {
    "deny": [
      "group:web",
      "browser",
      "exec",
      "process",
      "write",
      "edit",
      "apply_patch"
    ],
    "fs": {
      "workspaceOnly": true
    },
    "media": {
      "image": {
        "enabled": true,
        "maxBytes": 10485760,
        "maxChars": 500,
        "attachments": {
          "mode": "all",
          "maxAttachments": 3
        }
      },
      "audio": {
        "enabled": true,
        "maxBytes": 20971520,
        "models": [
          {
            "type": "cli",
            "command": "powershell",
            "args": [
              "-NoProfile",
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "C:\\Users\\YOUR_USER\\.local\\bin\\openclaw-whisper-stt.ps1",
              "{{MediaPath}}"
            ],
            "timeoutSeconds": 120
          }
        ]
      }
    },
    "web": {
      "search": {
        "enabled": false,
        "provider": "duckduckgo"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "messages": {
    "inbound": {
      "byChannel": {
        "whatsapp": {
          "debounceMs": 5000
        }
      }
    },
    "queue": {
      "mode": "collect",
      "debounceMs": 2500
    },
    "tts": {
      "auto": "off",
      "provider": "microsoft",
      "microsoft": {
        "enabled": true,
        "voice": "es-AR-TomasNeural",
        "lang": "es-AR",
        "outputFormat": "audio-24khz-48kbitrate-mono-mp3",
        "rate": "-5%",
        "pitch": "-8%"
      }
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": [
        "*"
      ],
      "selfChatMode": true,
      "groupPolicy": "allowlist",
      "mediaMaxMb": 50
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "lead-crm": {
          "enabled": true,
          "env": {
            "LEAD_DESTINATION": "+549XXXXXXXXXX",
            "LEAD_FORWARD_MEDIA": "true",
            "N8N_WEBHOOK_URL": "http://127.0.0.1:5678/webhook/galfredev-twenty-forward",
            "CRM_FANOUT_WEBHOOK_URLS": ""
          }
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "replace-with-secure-token"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "skills": {
    "entries": {
      "openai-whisper-api": {
        "apiKey": "replace-with-openai-api-key"
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "none"
    },
    "entries": {}
  }
}
