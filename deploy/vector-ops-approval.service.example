[Unit]
Description=Vector Ops approval poller
After=network-online.target openclaw-galfre.service
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/galfre-bot/openclaw
Environment=VECTOR_HOME=/opt/galfre-bot
Environment=VECTOR_STATE_DIR=/opt/galfre-bot/.openclaw
Environment=VECTOR_WORKSPACE_DIR=/opt/galfre-bot/.openclaw/workspace
Environment=VECTOR_REPO_DIR=/opt/galfre-bot/openclaw
Environment=VECTOR_OPENCLAW_USER=openclaw
Environment=VECTOR_OPENCLAW_BIN=/opt/galfre-bot/.local/bin/openclaw
Environment=VECTOR_APPROVER_NUMBER=+5493571606142
Environment=VECTOR_APPROVER_NAME=Valentino
Environment=VECTOR_SERVICE_NAME=openclaw-galfre.service
ExecStart=/usr/bin/node /opt/galfre-bot/openclaw/scripts/vector-improvement-check-approval.mjs

