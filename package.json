{
  "name": "openclaw-galfredev",
  "version": "0.1.0",
  "private": true,
  "description": "Bot comercial de WhatsApp para GalfreDev, construido sobre OpenClaw.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate:workflows": "node ./scripts/validate-workflows.mjs",
    "validate:crm-payload": "node ./scripts/validate-crm-payload.mjs",
    "check:bot": "node ./scripts/check-bot-runtime.mjs",
    "check": "npm run typecheck && npm run validate:workflows"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
